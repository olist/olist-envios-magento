{
    "name": "olist/envios-magento2",
    "description": "Módulo oficial de fretes Envios da Olist para Magento 2",
    "type": "magento2-module",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "magento/framework": "^103.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Olist\\Envios\\": ""
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "Test/Stub/Package/magento-framework",
            "options": {"symlink": false}
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Olist\\Envios\\Test\\": "Test/",
            "Magento\\": "Test/Stub/Magento/"
        }
    }
}
